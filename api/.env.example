# Base de datos
DATABASE_URL=postgresql://epoxiron:PASSWORD@postgres:5432/epoxiron

# Servidor
PORT=3001
NODE_ENV=production

# CORS
CORS_ORIGIN=https://wwwmarcos-alvarez.com

# Hermes/Epoxi agent
HERMES_SHARED_SECRET=change-me
HERMES_TIMEOUT_MS=15000
HERMES_BASE_URL=http://hermes:8642

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google Drive
GOOGLE_DRIVE_ENABLED=false
GOOGLE_DRIVE_ROOT_FOLDER_ID=your-google-drive-root-folder-id
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project-id.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# JWT
JWT_SECRET=generate-with-openssl-rand-hex-32
JWT_EXPIRES_IN=7d

# Emails autorizados (separados por coma)
ALLOWED_EMAILS=email1@gmail.com,email2@gmail.com
