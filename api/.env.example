# Base de datos
DATABASE_URL=postgresql://epoxiron:PASSWORD@postgres:5432/epoxiron

# Servidor
PORT=3001
NODE_ENV=production

# CORS
CORS_ORIGIN=https://wwwmarcos-alvarez.com

# Hermes/Epoxi agent
HERMES_SHARED_SECRET=change-me
HERMES_TIMEOUT_MS=15000
HERMES_BASE_URL=http://hermes:8642

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google Drive (rclone)
GOOGLE_DRIVE_ENABLED=false
RCLONE_REMOTE=gdrive:Epoxiron albaranes
RCLONE_CONFIG_PATH=/root/.hermes/rclone.conf

# JWT
JWT_SECRET=generate-with-openssl-rand-hex-32
JWT_EXPIRES_IN=7d

# Emails autorizados (separados por coma)
ALLOWED_EMAILS=email1@gmail.com,email2@gmail.com
