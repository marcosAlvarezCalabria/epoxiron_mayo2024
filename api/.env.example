# Base de datos
DATABASE_URL=postgresql://epoxiron:PASSWORD@postgres:5432/epoxiron

# Servidor
PORT=3001
NODE_ENV=production

# CORS
CORS_ORIGIN=https://wwwmarcos-alvarez.com

# Hermes/Epoxi agent
HERMES_SHARED_SECRET=change-me
HERMES_TIMEOUT_MS=15000
HERMES_BASE_URL=http://hermes:8642
VOICE_PARSER_PROVIDER=ollama
VOICE_PARSER_BASE_URL=http://127.0.0.1:11434
VOICE_PARSER_MODEL=llama3.1:8b
VOICE_PARSER_API_KEY=
VOICE_PARSER_TIMEOUT_MS=15000
VOICE_TRANSCRIBER_PROVIDER=gemini
VOICE_TRANSCRIBER_BASE_URL=https://generativelanguage.googleapis.com/v1beta
VOICE_TRANSCRIBER_MODEL=gemini-3.5-flash
VOICE_TRANSCRIBER_API_KEY=
VOICE_TRANSCRIBER_TIMEOUT_MS=30000
VOICE_TRANSCRIBER_LANGUAGE=es

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Cloudflare R2
REPORT_UPLOADS_ENABLED=false
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=epoxiron-albaranes
R2_PUBLIC_BASE_URL=https://archivos.wwwmarcos-alvarez.com
DAILY_REPORT_AUTOMATION_ENABLED=false
DAILY_REPORT_AUTOMATION_HOUR=18
DAILY_REPORT_AUTOMATION_MINUTE=0
EMAIL_NOTIFICATIONS_ENABLED=false
EMAIL_FROM=notificaciones@tu-dominio-verificado.com
EMAIL_TO=calalva82@gmail.com
EMAIL_APP_PASSWORD=re_xxxxxxxxx

# JWT
JWT_SECRET=generate-with-openssl-rand-hex-32
JWT_EXPIRES_IN=7d

# Emails autorizados (separados por coma)
ALLOWED_EMAILS=email1@gmail.com,email2@gmail.com
